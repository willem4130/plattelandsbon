{
  "name": "oom-gerrit-vouchers",
  "version": "0.1.0",
  "description": "Oom Gerrit Voucher System (Plattelandsbon) - Dutch rural tourism voucher platform with AI-powered recommendations",
  "keywords": [
    "vouchers",
    "tourism",
    "rural",
    "netherlands",
    "ai-recommendations",
    "nextjs",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/willem4130/oom-gerrit-vouchers.git"
  },
  "bugs": {
    "url": "https://github.com/willem4130/oom-gerrit-vouchers/issues"
  },
  "homepage": "https://github.com/willem4130/oom-gerrit-vouchers#readme",
  "author": "Willem van den Berg",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.0",
